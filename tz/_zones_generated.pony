primitive _ZoneAmericaBogota
  fun observation_at(sec: I64, nsec: I64)
    : (Observation val | TzLookupError)
  =>
    if sec < 0 then
      ifdef "HISTORICAL_TZ" then
        if sec < -2707671824 then _TzData._make_observation(sec, nsec, -17776, "LMT", false)
        elseif sec < -1739041424 then _TzData._make_observation(sec, nsec, -17776, "BMT", false)
        else _TzData._make_observation(sec, nsec, -18000, "-05", false)
        end
      else
        OutOfCoverage
      end
    elseif sec < 704869200 then _TzData._make_observation(sec, nsec, -18000, "-05", false)
    elseif sec < 729057600 then _TzData._make_observation(sec, nsec, -14400, "-04", true)
    elseif sec < 2147483647 then _TzData._make_observation(sec, nsec, -18000, "-05", false)
    else
