primitive _ZonePacificHonolulu
  fun observation_at(sec: I64, nsec: I64)
    : (Observation val | TzLookupError)
  =>
    if sec < 0 then
      ifdef "HISTORICAL_TZ" then
        if sec < -2334101314 then _TzData._make_observation(sec, nsec, -37886, "LMT", false)
        elseif sec < -1157283000 then _TzData._make_observation(sec, nsec, -37800, "HST", false)
        elseif sec < -1155436200 then _TzData._make_observation(sec, nsec, -34200, "HDT", true)
        elseif sec < -880198200 then _TzData._make_observation(sec, nsec, -37800, "HST", false)
        elseif sec < -769395600 then _TzData._make_observation(sec, nsec, -34200, "HWT", true)
        elseif sec < -765376200 then _TzData._make_observation(sec, nsec, -34200, "HPT", true)
        elseif sec < -712150200 then _TzData._make_observation(sec, nsec, -37800, "HST", false)
        else _TzData._make_observation(sec, nsec, -36000, "HST", false)
        end
      else
        OutOfCoverage
      end
    else
      _TzData._make_observation(sec, nsec, -36000, "HST", false)
    end


