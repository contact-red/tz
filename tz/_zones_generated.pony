primitive _ZoneMST7MDT
  fun observation_at(sec: I64, nsec: I64)
    : (Observation val | TzLookupError)
  =>
    if sec < 0 then
      ifdef "HISTORICAL_TZ" then
        if sec < -1633273200 then _TzData._make_observation(sec, nsec, -25200, "MST", false)
        elseif sec < -1615132800 then _TzData._make_observation(sec, nsec, -21600, "MDT", true)
        elseif sec < -1601823600 then _TzData._make_observation(sec, nsec, -25200, "MST", false)
