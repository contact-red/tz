primitive _ZoneAmericaCostaRica
  fun observation_at(sec: I64, nsec: I64)
    : (Observation val | TzLookupError)
  =>
    if sec < 0 then
      ifdef "HISTORICAL_TZ" then
        if sec < -2524501427 then _TzData._make_observation(sec, nsec, -20173, "LMT", false)
        elseif sec < -1545071027 then _TzData._make_observation(sec, nsec, -20173, "SJMT", false)
        else _TzData._make_observation(sec, nsec, -21600, "CST", false)
        end
      else
        OutOfCoverage
