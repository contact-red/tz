      (let year_for_posix = _TzData._year_from_utc_sec(sec)
      let spring = _TzData.mwd_local_to_utc(year_for_posix, 3, 4, 4, 180000, -7200)
      let fall = _TzData.mwd_local_to_utc(year_for_posix, 10, 4, 4, 180000, -10800)
      if (sec >= spring) and (sec < fall) then
        _TzData._make_observation(sec, nsec, 10800, "EEST", true)
      else
        _TzData._make_observation(sec, nsec, 7200, "EET", false)
      end)
    end


