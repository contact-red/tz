        if sec < -1946186240 then _TzData._make_observation(sec, nsec, 26240, "LMT", false)
        elseif sec < -1172906240 then _TzData._make_observation(sec, nsec, 26240, "PMT", false)
        elseif sec < -881220600 then _TzData._make_observation(sec, nsec, 27000, "+0730", false)
        elseif sec < -766054800 then _TzData._make_observation(sec, nsec, 32400, "+09", false)
        elseif sec < -683883000 then _TzData._make_observation(sec, nsec, 27000, "+0730", false)
        elseif sec < -620812800 then _TzData._make_observation(sec, nsec, 28800, "+08", false)
        elseif sec < -189415800 then _TzData._make_observation(sec, nsec, 27000, "+0730", false)
        else _TzData._make_observation(sec, nsec, 28800, "WITA", false)
        end
      else
        OutOfCoverage
