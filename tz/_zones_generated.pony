primitive _ZoneAmericaStThomas
  fun observation_at(sec: I64, nsec: I64)
    : (Observation val | TzLookupError)
  =>
    if sec < 0 then
      ifdef "HISTORICAL_TZ" then
        if sec < -1846266016 then _TzData._make_observation(sec, nsec, -15584, "LMT", false)
        else _TzData._make_observation(sec, nsec, -14400, "AST", false)
        end
      else
        OutOfCoverage
      end
    else
      _TzData._make_observation(sec, nsec, -14400, "AST", false)
    end


