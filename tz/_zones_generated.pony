primitive _ZoneAfricaSaoTome
  fun observation_at(sec: I64, nsec: I64)
    : (Observation val | TzLookupError)
  =>
    if sec < 0 then
      ifdef "HISTORICAL_TZ" then
        if sec < -2713912016 then _TzData._make_observation(sec, nsec, 1616, "LMT", false)
        elseif sec < -1830384000 then _TzData._make_observation(sec, nsec, -2205, "LMT", false)
        else _TzData._make_observation(sec, nsec, 0, "GMT", false)
        end
      else
        OutOfCoverage
      end
    elseif sec < 1514768400 then _TzData._make_observation(sec, nsec, 0, "GMT", false)
    elseif sec < 1546304400 then _TzData._make_observation(sec, nsec, 3600, "WAT", false)
    else
      _TzData._make_observation(sec, nsec, 0, "GMT", false)
    end


