primitive _ZoneAmericaCampoGrande
  fun observation_at(sec: I64, nsec: I64)
    : (Observation val | TzLookupError)
  =>
    if sec < 0 then
      ifdef "HISTORICAL_TZ" then
        if sec < -1767212492 then _TzData._make_observation(sec, nsec, -13108, "LMT", false)
        elseif sec < -1206954000 then _TzData._make_observation(sec, nsec, -14400, "-04", false)
        elseif sec < -1191358800 then _TzData._make_observation(sec, nsec, -10800, "-03", true)
        elseif sec < -1175371200 then _TzData._make_observation(sec, nsec, -14400, "-04", false)
