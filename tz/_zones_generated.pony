primitive _ZoneAmericaParamaribo
  fun observation_at(sec: I64, nsec: I64)
    : (Observation val | TzLookupError)
  =>
    if sec < 0 then
      ifdef "HISTORICAL_TZ" then
        if sec < -1861906760 then _TzData._make_observation(sec, nsec, -13240, "LMT", false)
        elseif sec < -1104524348 then _TzData._make_observation(sec, nsec, -13252, "PMT", false)
        elseif sec < -765317964 then _TzData._make_observation(sec, nsec, -13236, "PMT", false)
        else _TzData._make_observation(sec, nsec, -12600, "-0330", false)
        end
      else
        OutOfCoverage
      end
    elseif sec < 465449400 then _TzData._make_observation(sec, nsec, -12600, "-0330", false)
    elseif sec < 2147483647 then _TzData._make_observation(sec, nsec, -10800, "-03", false)
    else
      _TzData._make_observation(sec, nsec, -10800, "-03", false)
    end


