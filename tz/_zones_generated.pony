        elseif sec < -765388800 then _TzData._make_observation(sec, nsec, -21600, "MPT", true)
        elseif sec < -84380400 then _TzData._make_observation(sec, nsec, -25200, "MST", false)
        elseif sec < -68659200 then _TzData._make_observation(sec, nsec, -21600, "MDT", true)
        elseif sec < -52930800 then _TzData._make_observation(sec, nsec, -25200, "MST", false)
