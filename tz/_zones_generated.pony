    elseif sec < 2057209200 then _TzData._make_observation(sec, nsec, -18000, "EST", false)
    elseif sec < 2077768800 then _TzData._make_observation(sec, nsec, -14400, "EDT", true)
    elseif sec < 2088658800 then _TzData._make_observation(sec, nsec, -18000, "EST", false)
    elseif sec < 2109218400 then _TzData._make_observation(sec, nsec, -14400, "EDT", true)
    elseif sec < 2120108400 then _TzData._make_observation(sec, nsec, -18000, "EST", false)
    elseif sec < 2140668000 then _TzData._make_observation(sec, nsec, -14400, "EDT", true)
    else
      (let year_for_posix = _TzData._year_from_utc_sec(sec)
      let spring = _TzData.mwd_local_to_utc(year_for_posix, 3, 2, 0, 7200, 18000)
      let fall = _TzData.mwd_local_to_utc(year_for_posix, 11, 1, 0, 7200, 14400)
      if (sec >= spring) and (sec < fall) then
        _TzData._make_observation(sec, nsec, -14400, "EDT", true)
      else
        _TzData._make_observation(sec, nsec, -18000, "EST", false)
      end)
    end


