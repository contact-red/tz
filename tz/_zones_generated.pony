primitive _ZoneAmericaCaracas
  fun observation_at(sec: I64, nsec: I64)
    : (Observation val | TzLookupError)
  =>
    if sec < 0 then
      ifdef "HISTORICAL_TZ" then
        if sec < -2524505536 then _TzData._make_observation(sec, nsec, -16064, "LMT", false)
        elseif sec < -1826739140 then _TzData._make_observation(sec, nsec, -16060, "CMT", false)
        elseif sec < -157750200 then _TzData._make_observation(sec, nsec, -16200, "-0430", false)
        else _TzData._make_observation(sec, nsec, -14400, "-04", false)
        end
      else
        OutOfCoverage
      end
    elseif sec < 1197183600 then _TzData._make_observation(sec, nsec, -14400, "-04", false)
    elseif sec < 1462086000 then _TzData._make_observation(sec, nsec, -16200, "-0430", false)
    elseif sec < 2147483647 then _TzData._make_observation(sec, nsec, -14400, "-04", false)
    else
      _TzData._make_observation(sec, nsec, -14400, "-04", false)
    end


