primitive _ZoneAfricaKhartoum
  fun observation_at(sec: I64, nsec: I64)
    : (Observation val | TzLookupError)
  =>
    if sec < 0 then
      ifdef "HISTORICAL_TZ" then
        if sec < -1230775808 then _TzData._make_observation(sec, nsec, 7808, "LMT", false)
        else _TzData._make_observation(sec, nsec, 7200, "CAT", false)
        end
      else
