primitive _ZoneAmericaAsuncion
  fun observation_at(sec: I64, nsec: I64)
    : (Observation val | TzLookupError)
  =>
    if sec < 0 then
      ifdef "HISTORICAL_TZ" then
        if sec < -2524507760 then _TzData._make_observation(sec, nsec, -13840, "LMT", false)
        elseif sec < -1206389360 then _TzData._make_observation(sec, nsec, -13840, "AMT", false)
        else _TzData._make_observation(sec, nsec, -14400, "-04", false)
        end
      else
        OutOfCoverage
